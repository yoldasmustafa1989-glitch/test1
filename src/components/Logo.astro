---
import { SITE } from 'astrowind:config';

// Professional image link for your test
const logoUrl = "data:image/png;base64,";
---

<span class="flex items-center self-center ml-2 rtl:ml-0 rtl:mr-2 text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap">
  <img 
    src={logoUrl} 
    alt="Vakman de Groot Logo" 
    class="w-10 h-10 mr-2 rounded-full border border-gray-200 object-cover"
    loading="eager"
  />
  {SITE?.name}
</span>