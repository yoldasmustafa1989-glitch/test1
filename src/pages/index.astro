---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Loodgieter Haarlem · Direct hulp bij uw klus · Vakman de Groot',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Gratis Offerte Aanvragen',
        href: '/contact',
        icon: 'tabler:file-description',
      },
      { 
        text: 'WhatsApp ons direct', 
        href: 'https://wa.me/31612345678', 
        icon: 'tabler:brand-whatsapp',
        target: '_blank' 
      },
    ]}
    image={{ src: 'https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&w=2000&q=80', alt: 'Loodgieter Haarlem' }}
  >
    <Fragment slot="title">
      <span class="text-accent">Loodgieter in Haarlem</span>
      <span class="hidden xl:inline"> – Direct hulp bij </span>uw klus
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-black">Gecertificeerd vakman in regio Haarlem.</span> 
      Binnen 30 minuten ter plaatse bij spoedgevallen. Transparante prijzen en 100% garantie op al ons werk.
    </Fragment>
  </Hero>

  <Note title="Onze Belofte:" description="Snel, Betrouwbaar en Zonder Voorrijkosten in Haarlem." />

  <Features
    id="features"
    tagline="Diensten"
    title="Waarmee kunnen we u helpen?"
    subtitle="Van kleine lekkages tot volledige badkamerrenovaties, wij staan voor u klaar."
    items={[
      {
        title: 'Lekkage Verhelpen',
        description:
          'Snel opsporen en repareren van waterlekkages in muren, vloeren of daken om verdere schade te voorkomen.',
        icon: 'tabler:droplet-half-2',
      },
      {
        title: 'CV-Ketel Service',
        description:
          'Onderhoud, reparatie en installatie van alle merken CV-ketels voor een warm en veilig huis.',
        icon: 'tabler:flame',
      },
      {
        title: 'Ontstopping',
        description:
          'Hardnekkige verstopping in uw afvoer of riool? Wij lossen het snel en vakkundig voor u op.',
        icon: 'tabler:tool',
      },
      {
        title: 'Badkamer Renovatie',
        description:
          'Van een nieuwe kraan tot een complete verbouwing. Wij realiseren uw droombadkamer van A tot Z.',
        icon: 'tabler:bath',
      },
      {
        title: 'Spoedservice 24/7',
        description:
          "Dag en nacht bereikbaar voor noodgevallen. Wij laten u niet in de kou (of het water) staan.",
        icon: 'tabler:clock',
      },
      {
        title: 'Vrijblijvend Advies',
        description:
          'Heeft u een vraag over een klus? Wij denken graag met u mee en geven eerlijk advies.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <Stats
    stats={[
      { title: 'Klusjes Geklaard', amount: '1.2K+' },
      { title: 'Tevreden Klanten', amount: '98%' },
      { title: 'Jaar Ervaring', amount: '15' },
      { title: 'Garantie (Jaar)', amount: '2' },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Bel Nu: 06 1234 5678',
        href: 'tel:+31612345678',
        icon: 'tabler:phone',
      },
    ]}
  >
    <Fragment slot="title">
      Heeft u direct een vakman nodig?
    </Fragment>

    <Fragment slot="subtitle">
      Wacht niet tot de schade groter wordt. Bel ons direct voor een afspraak of een vrijblijvende prijsopgave.
    </Fragment>
  </CallToAction>
</Layout>